# filmroad backend 환경변수 템플릿.
# 실제 값으로 채운 뒤 `.env` 로 복사해서 사용. 이 파일은 커밋되지만 `.env` 는 커밋되지 않음.
# Spring Boot(application-dev.yml) 이 아래 키들을 참조한다.

# ---- Database (MariaDB) ----
DB_URL=jdbc:mariadb://localhost:3306/filmroad
DB_USER=root
DB_PASSWORD=change-me

# ---- JWT 서명 키 (최소 64자 이상 권장, HMAC-SHA256) ----
JWT_SECRET=replace-with-long-random-string-at-least-64-chars-for-hmac-256

# ---- AES (선택: 지정 안 하면 dev fallback 사용, 운영에서는 반드시 지정) ----
# AES_SECRET_KEY=32-byte-aes-key

# ---- SMTP (Gmail 앱 비밀번호 권장) ----
MAIL_ADDR=your-email@gmail.com
MAIL_PASSWORD=your-16-char-gmail-app-password

# ---- PortOne (결제) ----
PORTONE_SECRET=your-portone-v2-secret

# ---- OAuth2: Google ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# ---- OAuth2: Kakao ----
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao

# ---- 이미지 업로드 경로 (절대경로) ----
UPLOAD_PATH=/tmp/filmroad-uploads

# ---- SSL 인증서 키스토어 비밀번호 (HTTPS 로컬 구동 시) ----
SSL_KEY_STORE_PASSWORD=change-me
