# filmroad frontend 환경변수 템플릿 (Vite).
# 실제 값으로 채운 뒤 `.env.development` / `.env.production` 으로 복사해서 사용.
# VITE_* 접두사 변수만 빌드 시 클라이언트 번들에 포함된다.

# 카카오 개발자 콘솔 > 내 앱 > 앱 키 > JavaScript 키
# 주의: JS 키는 브라우저 번들에 노출되므로 카카오 콘솔에서 배포 도메인 제한을 걸 것.
VITE_KAKAO_MAP_KEY=your-kakao-javascript-key

# 백엔드 API 주소
#  - 개발: http://localhost:8080 (Spring Boot 로컬) 또는 ""(Vite 프록시 사용 시 same-origin 상대경로)
#  - 배포: https://api.example.com 또는 nginx 프록시 경로 "/api"
VITE_API_BASE_URL=http://localhost:8080
